generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @db.Timestamptz(6)
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model court {
  id             BigInt                    @id @default(autoincrement())
  created_at     DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?                 @db.Timestamptz(6)
  name           String?
  location       String?
  image          String?
  player_live    BigInt?                   @default(0)
  longitude      Float?
  latitude       Float?
  geom           Unsupported("geography")?
  occupancy_log  occupancy_log[]
  review         review[]
  session_invite session_invite[]

  @@index([geom], map: "idx_court_geom", type: Gist)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model review {
  id         BigInt    @id @default(autoincrement())
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  court_id   BigInt?
  user_id    String?
  thoughts   String?
  stars      Int?
  court      court?    @relation(fields: [court_id], references: [id], onDelete: Cascade)
  user       user?     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, court_id], map: "unique_user_court_review")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model session {
  id             String   @id
  expiresAt      DateTime @db.Timestamptz(6)
  token          String   @unique
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @db.Timestamptz(6)
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user {
  id                  String                @id
  name                String
  email               String                @unique
  emailVerified       Boolean
  image               String?
  createdAt           DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime              @default(now()) @db.Timestamptz(6)
  role                String?
  banned              Boolean?
  banReason           String?
  banExpires          DateTime?             @db.Timestamptz(6)
  account             account[]
  review              review[]
  session             session[]
  session_invite      session_invite[]
  session_participant session_participant[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([identifier])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model occupancy_log {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  court_id   BigInt?
  player_ct  BigInt
  court      court?   @relation(fields: [court_id], references: [id], onDelete: Cascade)

  @@map("occupancy-log")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model session_invite {
  id                  BigInt                @id @default(autoincrement())
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @db.Timestamptz(6)
  court_id            BigInt
  host_id             String
  title               String?
  skill_level         String
  players_have        Int
  spots_total         Int
  spots_filled        Int?                  @default(0)
  starts_at           DateTime              @db.Timestamptz(6)
  ends_at             DateTime              @db.Timestamptz(6)
  status              String?               @default("open")
  court               court                 @relation(fields: [court_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_court")
  user                user                  @relation(fields: [host_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_host")
  session_participant session_participant[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model session_participant {
  id             BigInt         @id @default(autoincrement())
  created_at     DateTime?      @default(now()) @db.Timestamptz(6)
  session_id     BigInt
  user_id        String
  session_invite session_invite @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_session")
  user           user           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@unique([session_id, user_id], map: "unique_session_user")
}
